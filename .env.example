# Optional local LLM summarization with Ollama. No API key is required.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Optional local cache override.
# By default, cache is stored in your OS local app data/cache directory outside the repo.
# HRA_CACHE_PATH=C:\temp\hra\cache.sqlite3

# Optional contact email for the Europe PMC user agent.
HRA_EUROPE_PMC_EMAIL=

# Optional: set true only if you need system proxy environment variables for Europe PMC.
HRA_TRUST_ENV=false
