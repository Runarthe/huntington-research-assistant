# Optional local LLM summarization with Ollama. No API key is required.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_NORWEGIAN_MODEL=hf.co/norallm/normistral-7b-warm-instruct:Q4_K_M
# Developer preview only. Norwegian generation is disabled by default because it has not passed linguistic review.
HRA_ENABLE_EXPERIMENTAL_NORWEGIAN_SUMMARIES=false

# Optional local cache override.
# By default, cache is stored in your OS local app data/cache directory outside the repo.
# HRA_CACHE_PATH=C:\temp\hra\cache.sqlite3

# Optional contact email for the Europe PMC user agent.
HRA_EUROPE_PMC_EMAIL=

# Optional: set true only if provider requests should use system proxy environment variables.
HRA_TRUST_ENV=false
